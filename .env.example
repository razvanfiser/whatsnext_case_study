# OpenAI
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o-mini

# LLM request timeout in seconds (OpenAI client)
LLM_TIMEOUT_SECONDS=60

# Postgres (docker-compose db service). Copy this file to .env and set values locally.
POSTGRES_USER=buildit
POSTGRES_PASSWORD=change-me
POSTGRES_DB=buildit

# SQLAlchemy / app (inside Docker, host is the compose service name `db`)
DATABASE_URL=postgresql+psycopg://buildit:change-me@db:5432/buildit
