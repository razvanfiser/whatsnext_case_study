# OpenAI
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o-mini

# LLM request timeout in seconds (OpenAI client)
LLM_TIMEOUT_SECONDS=60

# Postgres (docker-compose db service). Copy this file to `.env` and set values locally.
# Keep POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB aligned with the credentials and
# database name you embed in DATABASE_URL below.
POSTGRES_USER=buildit
POSTGRES_PASSWORD=change-me
POSTGRES_DB=buildit

# SQLAlchemy URL for the app. Use host `db` when the API runs inside Compose; use
# `localhost` when you run uvicorn on the host but only the db container is from Compose.
DATABASE_URL=postgresql+psycopg://buildit:change-me@db:5432/buildit
# DATABASE_URL=postgresql+psycopg://buildit:change-me@localhost:5432/buildit
